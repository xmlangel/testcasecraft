# .env.dev.example - 개발 환경 환경 변수 예시
# 이 파일을 .env.dev로 복사하고 실제 값을 설정하세요

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# JWT 설정 (개발용)
JWT_SECRET=dev512bitsecretkeyhere1234567890abcdefghijklmnopqrstuvwxyz1234567890abcdefghijklmnopqrstuvwxyz

# JIRA 설정 (개발용)
JIRA_ENCRYPTION_KEY=5CBRv5FwesBJkQ7ecX1KGCxyUQTcnE1CkkGBYDswb2Y=
JIRA_AUTO_COMMENT_ENABLED=true
JIRA_SCHEDULER_ENABLED=false

# 구글 OAuth (개발용 - 실제 클라이언트 ID/Secret 필요)
GOOGLE_CLIENT_ID=your-dev-google-client-id
GOOGLE_CLIENT_SECRET=your-dev-google-client-secret

# 메일 설정 (개발용)
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# 기타 개발 설정
LOG_LEVEL_ROOT=DEBUG