# ===================================
# Spring Boot Configuration (H2)
# ===================================
# H2 전용 프로파일 설정
SPRING_PROFILES_ACTIVE=dev

# H2 데이터베이스 설정 (명시적으로 지정하지 않음 - application-dev.yml 사용)
# SPRING_DATASOURCE_URL, SPRING_DATASOURCE_USERNAME 등은 설정하지 않음
# H2 설정은 application-dev.yml에서 관리

# ===================================
# ICT-340: Frontend Environment Variables
# ===================================
# 프론트엔드 환경변수 기반 API 엔드포인트 관리 시스템

# 기본 API URL (H2 개발환경)
REACT_APP_API_BASE_URL=http://localhost:8080

# 환경 설정
REACT_APP_ENV=development
REACT_APP_USE_DEMO_DATA=false

# API 설정
REACT_APP_API_TIMEOUT=30000
REACT_APP_API_RETRY_COUNT=3
REACT_APP_API_RETRY_DELAY=1000

# 개발환경 디버깅 설정
REACT_APP_DEBUG_MODE=true
REACT_APP_LOG_LEVEL=debug
REACT_APP_SHOW_DEV_TOOLS=true