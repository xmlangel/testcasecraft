# ===================================
# HTTP Only Environment Configuration
# ===================================
# 이 파일을 .env.http로 복사한 후 값 편집하세요
# cp .env.http.example .env.http

# ===================================
# Domain Configuration (HTTP Only)
# ===================================
# 도메인 또는 IP 주소
DOMAIN_NAME=qaspecialist.uk
# HTTPS 비활성화
ENABLE_HTTPS=false
# Certbot 이메일 (HTTP에서는 필요없음)
CERTBOT_EMAIL=
CERTBOT_EXTRA_DOMAINS=

# ===================================
# Database Configuration
# ===================================
POSTGRES_DB=testcase_management
POSTGRES_USER=testcase_user
POSTGRES_PASSWORD=your_strong_database_password_here
POSTGRES_PORT=5432

# ===================================
# Redis Configuration
# ===================================
REDIS_PASSWORD=your_strong_redis_password_here
REDIS_PORT=6379

# ===================================
# Application Security
# ===================================
# JWT Secret (512비트 이상, base64 인코딩 권장)
JWT_SECRET=your_very_strong_512_bit_jwt_secret_key_here_make_it_very_long_and_random_at_least_64_characters
# JIRA 암호화 키 (32바이트, base64 인코딩)
JIRA_ENCRYPTION_KEY=5CBRv5FwesBJkQ7ecX1KGCxyUQTcnE1CkkGBYDswb2Y=

# ===================================
# File Upload Configuration
# ===================================
# 파일 업로드 경로 (컨테이너 내부 경로)
UPLOAD_PATH=/app/uploads
# 최대 업로드 파일 크기 (Nginx와 백엔드에서 사용)
MAX_UPLOAD_SIZE=100MB

# ===================================
# Monitoring & Logging
# ===================================
# 로그 레벨 (ERROR, WARN, INFO, DEBUG)
LOG_LEVEL=INFO
# 액세스 로그 활성화
ENABLE_ACCESS_LOG=true

# ===================================
# Performance Settings
# ===================================
# JVM 메모리 옵션 설정
JAVA_OPTS="-Xmx2g -Xms1g"
# 데이터베이스 커넥션 풀 크기
DB_POOL_SIZE=20
# Redis 커넥션 풀 크기
REDIS_POOL_SIZE=10