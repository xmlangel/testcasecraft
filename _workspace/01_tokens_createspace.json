      }
    },
    "MuiRadio": {
      "styleOverrides": {
        "root": {
          "width": 20,
          "height": 20,
          "color": "#D1D5DB",
          "&.Mui-checked": {
            "color": "#2563EB"
          },
          "&.Mui-disabled": {
            "color": "#E5E7EB"
          },
          "&.Mui-focusVisible": {
            "boxShadow": "0 0 0 3px rgba(37, 99, 235, 0.35)"
          }
        }
      }
    },
    "MuiTooltip": {
      "styleOverrides": {
        "tooltip": {
          "backgroundColor": "#1F2937",
          "color": "#FFFFFF",
          "fontFamily": "'DM Sans', sans-serif",
          "fontSize": 13,
          "padding": "8px 14px",
          "borderRadius": 8,
          "maxWidth": 240,
          "boxShadow": "0px 4px 16px rgba(0, 0, 0, 0.1)"
        },
        "arrow": {
          "color": "#1F2937",
          "fontSize": 6
        }
      },
      "defaultProps": {
        "enterDelay": 200,
        "leaveDelay": 50
      }
    }
