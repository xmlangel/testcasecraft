    END,
    CURRENT_TIMESTAMP, -- 현재 시간 (최신)
    'ICT-265 최신 실행 결과 #' || ROW_NUMBER() OVER() || ' (최종 결과)',
    CURRENT_TIMESTAMP,
    CURRENT_TIMESTAMP
FROM (SELECT id FROM testcases WHERE name LIKE 'ICT265%' LIMIT 12) tc [42122-224]
