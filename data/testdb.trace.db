    'ICT-265 두 번째 실행 결과 #' || ROW_NUMBER() OVER(),
    CURRENT_TIMESTAMP,
    CURRENT_TIMESTAMP
FROM (SELECT id FROM testcases WHERE name LIKE 'ICT265%' LIMIT 15) tc [42122-224]
