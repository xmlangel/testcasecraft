INSERT INTO test_results (id, test_execution_id, test_case_id, result, executed_at, notes, created_at, updated_at)
SELECT 
    'result-' || ROW_NUMBER() OVER() || '-latest',
    'ict265-exec-001',
    tc.id,
    CASE 
        WHEN ROW_NUMBER() OVER() % 2 = 1 THEN 'PASS'
