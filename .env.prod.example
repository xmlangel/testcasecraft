# .env.prod.example - 운영 환경 환경 변수 예시
# 이 파일을 .env.prod로 복사하고 실제 값을 설정하세요

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# 서버 설정
SERVER_PORT=8080
MANAGEMENT_PORT=8083
CONTEXT_PATH=/

# JWT 설정 (운영용 - 강력한 시크릿 키 필요)
JWT_SECRET=CHANGE_THIS_TO_VERY_STRONG_512_BIT_SECRET_KEY
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# 데이터베이스 설정 (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/testcase_management
DATABASE_USERNAME=testcase_user
DATABASE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Redis 설정
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_TTL=600000

# JIRA 설정 (운영용)
JIRA_ENCRYPTION_KEY=CHANGE_THIS_TO_32_BYTE_BASE64_KEY
JIRA_CONNECTION_TIMEOUT=30000
JIRA_READ_TIMEOUT=60000
JIRA_CACHE_TTL=300000
JIRA_AUTO_COMMENT_ENABLED=true
JIRA_SCHEDULER_ENABLED=false
JIRA_AUDIT_LOG_ENABLED=true
JIRA_AUDIT_LOG_PATH=/var/log/testcase/jira-audit.log

# 구글 OAuth (운영용)
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret

# 메일 설정 (운영용 SMTP)
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-app-password

# 로그 설정
LOG_FILE=/var/log/testcase/application.log
LOG_MAX_SIZE=50MB
LOG_MAX_HISTORY=30
LOG_TOTAL_SIZE=1GB

# SSL 설정 (운영환경에서 사용)
SSL_KEY_STORE=/path/to/keystore.p12
SSL_KEY_STORE_PASSWORD=keystore_password
SSL_KEY_STORE_TYPE=PKCS12