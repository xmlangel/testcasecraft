# ===================================
# Production Environment Configuration
# ===================================
# 이 파일을 .env.prod로 복사하고 실제 값으로 수정하세요
# cp .env.prod.example .env.prod

# ===================================
# Domain & SSL Configuration
# ===================================
# 메인 도메인 (필수)
DOMAIN_NAME=qaspecialist.uk
# 추가 도메인 (선택적, 공백으로 구분)
EXTRA_DOMAINS=
# HTTPS 활성화 (true/false)
ENABLE_HTTPS=true
# Let's Encrypt 이메일 (HTTPS 사용시 필수)
CERTBOT_EMAIL=admin@qaspecialist.uk
# 추가 도메인 인증서 (선택적)
CERTBOT_EXTRA_DOMAINS=

# ===================================
# Database Configuration
# ===================================
POSTGRES_DB=testcase_management
POSTGRES_USER=testcase_user
POSTGRES_PASSWORD=your_strong_database_password_here
POSTGRES_PORT=5432


# ===================================
# Application Security
# ===================================
# JWT Secret (512비트 이상, Base64 인코딩 필수)
# 참고: JWT_SECRET은 반드시 Base64로 인코딩된 값을 사용해야 합니다
# 생성 방법: echo -n "your_secret_string" | base64
# 또는 온라인 Base64 인코더 사용
JWT_SECRET=your_very_strong_512_bit_jwt_secret_key_here_make_it_very_long_and_random_at_least_64_characters
# JIRA 암호화 키 (32바이트, Base64 인코딩 필수)
# 참고: 32바이트 랜덤 키를 Base64로 인코딩한 값
# 생성 방법: openssl rand -base64 32
JIRA_ENCRYPTION_KEY=5CBRv5FwesBJkQ7ecX1KGCxyUQTcnE1CkkGBYDswb2Y=

# ===================================
# File Upload Configuration
# ===================================
# 업로드 경로 (컨테이너 내부 경로)
UPLOAD_PATH=/app/uploads
# 최대 업로드 크기 (Nginx와 일치해야 함)
MAX_UPLOAD_SIZE=100MB

# ===================================
# Monitoring & Logging
# ===================================
# 로그 레벨 (ERROR, WARN, INFO, DEBUG)
LOG_LEVEL=INFO
# 액세스 로그 활성화
ENABLE_ACCESS_LOG=true
# 액추에이터 설정
MANAGEMENT_ENDPOINT_HEALTH_SHOW_COMPONENTS=NEVER
# CORS 설정 (Nginx 리버스 프록시 고려)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080

# ===================================
# Performance Settings
# ===================================
# JVM 힙 메모리 설정
JAVA_OPTS="-Xmx2g -Xms1g -XX:+UseG1GC -XX:+UseContainerSupport"
# 데이터베이스 연결 풀 크기
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5
DB_POOL_IDLE_TIMEOUT=600000
DB_POOL_MAX_LIFETIME=1800000

# ===================================
# Spring Boot Configuration (Production)
# ===================================
SPRING_PROFILES_ACTIVE=prod

# Database Configuration
DATABASE_URL=jdbc:postgresql://postgres:5432/testcase_management
DATABASE_USERNAME=testcase_user
DATABASE_PASSWORD=your_strong_database_password_here

# Server Configuration
SERVER_PORT=8080
MANAGEMENT_PORT=8083

# JWT Configuration
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=7776000000

# JIRA Configuration (Production)
JIRA_ENABLE_HTTPS=true
JIRA_SKIP_SSL_VERIFICATION=false
JIRA_CONNECTION_TIMEOUT=30000
JIRA_READ_TIMEOUT=60000
JIRA_RETRY_MAX_ATTEMPTS=3
JIRA_RETRY_DELAY=1000
JIRA_CONNECTION_POOL_MAX=20
JIRA_CONNECTION_POOL_IDLE_TIMEOUT=300000
JIRA_CACHE_TTL=300000
JIRA_CACHE_MAX_ENTRIES=1000
JIRA_HEALTH_CHECK_INTERVAL=3600000
JIRA_MONITORING_RETENTION=72
JIRA_AUDIT_LOG_ENABLED=true
JIRA_AUDIT_LOG_PATH=/var/log/testcase/jira-audit.log

# Application Frontend Configuration
REACT_APP_API_BASE_URL=https://qaspecialist.uk

# Logging Configuration
LOG_FILE=/var/log/testcase/application.log
LOG_MAX_SIZE=50MB
LOG_MAX_HISTORY=30
LOG_TOTAL_SIZE=1GB
