# PostgreSQL 데이터베이스 설정
POSTGRES_DB=testcase_management
POSTGRES_USER=testcase_user
POSTGRES_PASSWORD=testcase_password

# 애플리케이션 보안 설정 (테스트용 임시 값)
JWT_SECRET=a_very_long_and_complex_jwt_secret_key_for_testing_only_1234567890ABCDEF
JIRA_ENCRYPTION_KEY=a_very_long_and_complex_jira_encryption_key_for_testing_only_FEDCBA0987654321

# 도메인 및 Let's Encrypt 설정 (HTTP만 활성화)
ENABLE_HTTPS=false