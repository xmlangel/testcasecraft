# Production Environment Configuration
# ⚠️ 운영 배포 시 실제 서버 도메인으로 변경 필요
REACT_APP_API_BASE_URL=https://your-production-domain.com

# 운영환경 특성 설정
REACT_APP_USE_DEMO_DATA=false
REACT_APP_ENV=production

# API 설정 - 운영 최적화
REACT_APP_API_TIMEOUT=15000
REACT_APP_API_RETRY_COUNT=2
REACT_APP_API_RETRY_DELAY=2000

# 운영환경 보안 설정
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_LEVEL=error
REACT_APP_SHOW_DEV_TOOLS=false

# 캐시 및 성능 최적화
REACT_APP_CACHE_ENABLED=true
REACT_APP_ENABLE_SERVICE_WORKER=true