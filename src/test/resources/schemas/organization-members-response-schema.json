{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "description": "조직 사용자 고유 식별자"
      },
      "user": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["ADMIN", "TESTER", "USER"]
          },
          "createdAt": {
            "oneOf": [
              { "type": "string", "format": "date-time" },
              { "type": "array", "items": { "type": "integer" } }
            ]
          },
          "updatedAt": {
            "oneOf": [
              { "type": "string", "format": "date-time" },
              { "type": "array", "items": { "type": "integer" } }
            ]
          }
        },
        "required": [
          "id",
          "username",
          "email",
          "name",
          "role",
          "createdAt",
          "updatedAt"
        ],
        "additionalProperties": true
      },
      "roleInOrganization": {
        "type": "string",
        "enum": ["OWNER", "ADMIN", "MEMBER"],
        "description": "조직 내 역할"
      },
      "createdAt": {
        "oneOf": [
          { "type": "string", "format": "date-time" },
          { "type": "array", "items": { "type": "integer" } }
        ],
        "description": "가입 일시"
      },
      "updatedAt": {
        "oneOf": [
          { "type": "string", "format": "date-time" },
          { "type": "array", "items": { "type": "integer" } }
        ],
        "description": "수정 일시"
      },
      "organizationName": {
        "type": "string",
        "description": "조직 이름"
      },
      "owner": {
        "type": "boolean",
        "description": "소유자 여부"
      },
      "admin": {
        "type": "boolean",
        "description": "관리자 여부"
      },
      "userName": {
        "type": "string",
        "description": "사용자 이름"
      },
      "member": {
        "type": "boolean",
        "description": "일반 멤버 여부"
      }
    },
    "required": ["id", "user", "roleInOrganization", "createdAt", "updatedAt"],
    "additionalProperties": true
  }
}
