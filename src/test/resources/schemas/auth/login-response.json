{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "accessToken",
        "refreshToken",
        "tokenType",
        "accessTokenExpiration",
        "refreshTokenExpiration",
        "user"
    ],
    "properties": {
        "accessToken": {
            "type": "string",
            "minLength": 10
        },
        "refreshToken": {
            "type": "string",
            "minLength": 10
        },
        "tokenType": {
            "type": "string",
            "enum": [
                "Bearer"
            ]
        },
        "accessTokenExpiration": {
            "type": "integer",
            "minimum": 0
        },
        "refreshTokenExpiration": {
            "type": "integer",
            "minimum": 0
        },
        "user": {
            "type": "object",
            "required": [
                "id",
                "username",
                "name",
                "email",
                "role",
                "emailVerified",
                "preferredLanguage",
                "timezone"
            ],
            "properties": {
                "id": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "role": {
                    "type": "string"
                },
                "emailVerified": {
                    "type": "boolean"
                },
                "preferredLanguage": {
                    "type": "string"
                },
                "timezone": {
                    "type": "string"
                }
            }
        }
    }
}