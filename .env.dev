# ===================================
# Development Environment Configuration
# ===================================
# .env.dev - 개발 환경용 설정 파일
# start-dev.sh, start-dev-postgresql.sh 스크립트에서 이 파일을 로드하여 사용합니다.

# ===================================
# JIRA Configuration
# ===================================
# JIRA 암호화 키 (start-dev.sh, start-dev-postgresql.sh에서 공통으로 사용)
JIRA_ENCRYPTION_KEY=5CBRv5FwesBJkQ7ecX1KGCxyUQTcnE1CkkGBYDswb2Y=

# ===================================
# Database Configuration (For dev-postgresql profile)
# ===================================
POSTGRES_DB=testcase_management_dev
POSTGRES_USER=testcase_user
POSTGRES_PASSWORD=testcase_dev_password
POSTGRES_DEV_PORT=5433


# ===================================
# Application Configuration
# ===================================
# JWT Secret (개발용 - Base64 인코딩)
JWT_SECRET=ZGV2X2p3dF9zZWNyZXRfa2V5X2Zvcl9kZXZlbG9wbWVudF9vbmx5X3RoaXNfbXVzdF9iZV9hdF9sZWFzdF81MTJfYml0c19sb25nX3RvX3dvcmtfcHJvcGVybHlfd2l0aF9zcHJpbmdfc2VjdXJpdHlfYW5kX2p3dF90b2tlbl9nZW5lcmF0aW9uX3N5c3RlbQ==


# ===================================
# Spring Boot Configuration
# ===================================
SPRING_PROFILES_ACTIVE=dev-postgresql
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/testcase_management_dev
SPRING_DATASOURCE_USERNAME=testcase_user
SPRING_DATASOURCE_PASSWORD=testcase_dev_password

# ===================================
# ICT-340: Frontend Environment Variables
# ===================================
# 프론트엔드 환경변수 기반 API 엔드포인트 관리 시스템

# 기본 API URL (PostgreSQL 개발환경)
REACT_APP_API_BASE_URL=http://localhost:8080

# 환경 설정
REACT_APP_ENV=development
REACT_APP_USE_DEMO_DATA=false

# API 설정
REACT_APP_API_TIMEOUT=30000
REACT_APP_API_RETRY_COUNT=3
REACT_APP_API_RETRY_DELAY=1000

# 개발환경 디버깅 설정
REACT_APP_DEBUG_MODE=true
REACT_APP_LOG_LEVEL=debug
REACT_APP_SHOW_DEV_TOOLS=true
