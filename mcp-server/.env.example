# testcasecraft MCP Server Configuration

# Base URL of the testcasecraft API
TESTCASECRAFT_BASE_URL=http://localhost:8080

# Path to store authentication tokens (default: ~/.testcasecraft-mcp/token.json)
# TESTCASECRAFT_TOKEN_PATH=~/.testcasecraft-mcp/token.json

# HTTP request timeout in milliseconds (default: 30000)
TESTCASECRAFT_TIMEOUT_MS=30000
