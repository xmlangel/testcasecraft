# ===================================
# Development Environment Configuration with PostgreSQL
# ===================================
# PostgreSQL 개발환경용 설정 파일
# 사용법: cp .env.dev.postgresql .env.dev

# ===================================
# Database Configuration (Development PostgreSQL)
# ===================================
POSTGRES_DB=testcase_management_dev
POSTGRES_USER=testcase_user
POSTGRES_PASSWORD=testcase_dev_password
POSTGRES_DEV_PORT=5433


# ===================================
# Application Configuration
# ===================================
# JWT Secret (개발용 - 512비트 필수)
JWT_SECRET=dev_jwt_secret_key_for_development_only_this_must_be_at_least_512_bits_long_to_work_properly_with_spring_security_and_jwt_token_generation_system
# JIRA 암호화 키 (개발용)
JIRA_ENCRYPTION_KEY=5CBRv5FwesBJkQ7ecX1KGCxyUQTcnE1CkkGBYDswb2Y=

# ===================================
# Spring Boot Configuration
# ===================================
SPRING_PROFILES_ACTIVE=dev-postgresql

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5433/testcase_management_dev
DATABASE_USERNAME=testcase_user
DATABASE_PASSWORD=testcase_dev_password

# Database Pool Configuration
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_IDLE_TIMEOUT=300000
DB_POOL_MAX_LIFETIME=1200000

# Server Configuration
SERVER_PORT=8080

# JWT Configuration
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=7776000000

# JIRA Configuration
JIRA_ENABLE_HTTPS=false
JIRA_SKIP_SSL_VERIFICATION=true

# Legacy Support (deprecated, use DATABASE_* instead)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/testcase_management_dev
SPRING_DATASOURCE_USERNAME=testcase_user
SPRING_DATASOURCE_PASSWORD=testcase_dev_password
